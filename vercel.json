{
    "version": 2,
    "builds": [
        {
            "src": "client/package.json",
            "use": "@vercel/static-build",
            "config": { "distDir": "dist" }
        },
        {
            "src": "server/index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "/server/index.js" },
        { "src": "/assets/(.*)", "dest": "/assets/$1" },
        { "src": "/(.*\\.(ico|png|jpg|jpeg|svg|gif|json|txt|webmanifest|css|js))", "dest": "/$1" },
        { "src": "/(.*)", "dest": "/index.html" }
    ]
}